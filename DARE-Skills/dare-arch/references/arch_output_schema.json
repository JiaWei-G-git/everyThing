{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ARCH-Challenger Output Schema",
  "description": "D.A.R.E.框架架构阶段对抗审查的标准输出格式，含架构健康度评分(AHS)，与dare-report/references/unified_schema.json对齐",
  "type": "object",
  "required": [
    "record_id",
    "stage",
    "timestamp",
    "intensity_level",
    "review_summary",
    "issues",
    "scores",
    "gate_result",
    "confidence_score",
    "escalation_triggered"
  ],
  "additionalProperties": true,
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^dare-[0-9]{8}-[0-9]{3}$"
    },
    "stage": {
      "type": "string",
      "enum": ["ARCH"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "intensity_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "mode": {
      "type": "string",
      "enum": ["debate", "review", "audit"]
    },
    "participants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target": {
      "type": "object",
      "properties": {
        "file_path": { "type": "string" },
        "commit_sha": { "type": "string" },
        "module": { "type": "string" },
        "pr_number": { "type": "string" }
      }
    },
    "debate_rounds": {
      "type": "integer",
      "minimum": 0
    },
    "review_summary": {
      "type": "string",
      "maxLength": 200,
      "description": "审查结论摘要，200字以内"
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/definitions/issue" }
    },
    "scores": {
      "$ref": "#/definitions/scores"
    },
    "gate_result": {
      "type": "string",
      "enum": ["PASSED", "CONDITIONAL", "BLOCKED"]
    },
    "gate_reason": {
      "type": "string",
      "description": "门禁判定原因说明"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "escalation_triggered": {
      "type": "boolean",
      "default": false
    },
    "escalation_level": {
      "type": ["string", "null"],
      "enum": ["L1", "L2", "L3", null]
    },
    "human_override": {
      "type": ["object", "null"]
    },
    "feedback_score": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5
    },
    "metrics": {
      "$ref": "#/definitions/metrics"
    },
    "architecture_health_score": {
      "type": "number",
      "description": "架构健康度总分，范围 0-100（遗留字段，已映射到 scores.overall）",
      "minimum": 0,
      "maximum": 100
    },
    "dimension_scores": {
      "type": "object",
      "description": "四个审查维度的独立评分（遗留字段）",
      "properties": {
        "technical_selection": { "type": "number", "minimum": 0, "maximum": 100 },
        "robustness": { "type": "number", "minimum": 0, "maximum": 100 },
        "scalability": { "type": "number", "minimum": 0, "maximum": 100 },
        "tech_debt": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "alternative_proposals": {
      "type": "array",
      "description": "审查者提出的替代架构方案（ARCH阶段扩展）",
      "items": {
        "type": "object",
        "required": ["id", "target_decision", "proposal"],
        "properties": {
          "id": { "type": "string" },
          "target_decision": { "type": "string" },
          "proposal": { "type": "string" },
          "trade_offs": {
            "type": "object",
            "properties": {
              "pros": { "type": "array", "items": { "type": "string" } },
              "cons": { "type": "array", "items": { "type": "string" } },
              "migration_cost": { "type": "string" }
            }
          },
          "applicable_scenarios": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "overall_verdict": {
      "type": "object",
      "description": "Judge-Arch 综合裁决（遗留对象，gate_result已替代verdict字段）",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["PASSED", "CONDITIONAL", "BLOCKED"]
        },
        "summary": { "type": "string" },
        "top_priorities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "priority": { "type": "integer", "minimum": 1 },
              "item": { "type": "string" },
              "rationale": { "type": "string" }
            }
          }
        },
        "conditional_pass_deadline": { "type": "string" },
        "re_review_required": { "type": "boolean", "default": false }
      }
    }
  },
  "definitions": {
    "issue": {
      "type": "object",
      "required": ["issue_id", "dimension", "severity", "description", "evidence", "impact", "recommendation"],
      "properties": {
        "issue_id": {
          "type": "string",
          "pattern": "^ARCH-[0-9]{3}$"
        },
        "dimension": {
          "type": "string",
          "enum": ["maintainability", "reliability", "scalability"],
          "description": "technical_selection/tech_debt → maintainability; robustness → reliability; scalability → scalability"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "evidence": { "type": "string" },
        "impact": { "type": "string" },
        "recommendation": { "type": "string" },
        "location": { "type": "string" },
        "recurring": { "type": "boolean", "default": false },
        "recurring_count": { "type": "integer", "minimum": 1 },
        "first_seen": { "type": "string", "format": "date-time" },
        "remediation_effort": {
          "type": "string",
          "enum": ["trivial", "small", "medium", "large", "massive"]
        },
        "anti_pattern_ref": { "type": "string" }
      }
    },
    "scores": {
      "type": "object",
      "required": ["overall", "security", "maintainability", "performance"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 100, "description": "architecture_health_score 映射" },
        "security": { "type": "number", "minimum": 0, "maximum": 100, "description": "从 robustness/tech_debt 推导" },
        "maintainability": { "type": "number", "minimum": 0, "maximum": 100, "description": "从 technical_selection/tech_debt 推导" },
        "performance": { "type": "number", "minimum": 0, "maximum": 100, "description": "从 scalability 推导" },
        "reliability": { "type": "number", "minimum": 0, "maximum": 100, "description": "从 robustness 推导" },
        "scalability": { "type": "number", "minimum": 0, "maximum": 100, "description": "从 scalability 推导" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "issue_density": { "type": "number" },
        "critical_issue_ratio": { "type": "number" },
        "recurring_issue_ratio": { "type": "number" },
        "fix_duration_hours": { "type": "number" }
      }
    }
  }
}
