pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  - elementId: toc-deco
    elementType: text
    bounds: [40, 200, 400, 300]
    content:
      fontSize: 80
      color: "#E2E8F0"
      fontFamily: "Liter, MiSans"
      align: [left, middle]
      wrap: false
      letterSpacing: 4
      text: |
        <p>CONTENTS</p>
  - elementId: toc-title
    elementType: text
    bounds: [60, 60, 300, 50]
    content:
      style: "$pageTitle"
      align: [left, middle]
      wrap: false
      text: |
        <p>目录</p>
  - elementId: toc-divider
    elementType: shape
    shapeName: straightConnector1
    bounds: [60, 120, 60, 0]
    border:
      style: solid
      width: 3
      color: "$accent"
  - elementId: card1-bg
    elementType: shape
    shapeName: rect
    bounds: [460, 150, 360, 200]
    fill:
      type: solid
      color: "$cardBg"
  - elementId: card1-accent
    elementType: shape
    shapeName: rect
    bounds: [460, 150, 3, 200]
    fill:
      type: solid
      color: "$accent"
  - elementId: card1-num
    elementType: text
    bounds: [480, 170, 80, 50]
    content:
      style: "$number"
      align: [left, middle]
      wrap: false
      text: |
        <p>01</p>
  - elementId: card1-title
