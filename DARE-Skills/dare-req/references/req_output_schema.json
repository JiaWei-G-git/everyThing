{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "D.A.R.E. Requirement Review Output Schema",
  "description": "REQ-Challenger需求阶段对抗审查的标准输出格式，与dare-report/references/unified_schema.json对齐",
  "type": "object",
  "required": [
    "record_id",
    "stage",
    "timestamp",
    "intensity_level",
    "review_summary",
    "issues",
    "scores",
    "gate_result",
    "confidence_score",
    "escalation_triggered"
  ],
  "additionalProperties": true,
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^dare-[0-9]{8}-[0-9]{3}$"
    },
    "stage": {
      "type": "string",
      "enum": ["REQ"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "intensity_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "mode": {
      "type": "string",
      "enum": ["debate", "review", "audit", "council"]
    },
    "participants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target": {
      "type": "object",
      "properties": {
        "file_path": { "type": "string" },
        "commit_sha": { "type": "string" },
        "module": { "type": "string" },
        "pr_number": { "type": "string" }
      }
    },
    "debate_rounds": {
      "type": "integer",
      "minimum": 0
    },
    "review_summary": {
      "type": "string",
      "maxLength": 200,
      "description": "审查结论摘要，200字以内"
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/definitions/issue" }
    },
    "scores": {
      "$ref": "#/definitions/scores"
    },
    "gate_result": {
      "type": "string",
      "enum": ["PASSED", "CONDITIONAL", "BLOCKED"]
    },
    "gate_reason": {
      "type": "string",
      "description": "门禁判定原因说明"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Agent对审查结果的置信度（0=完全不确定，1=完全确信）"
    },
    "escalation_triggered": {
      "type": "boolean",
      "default": false
    },
    "escalation_level": {
      "type": ["string", "null"],
      "enum": ["L1", "L2", "L3", null]
    },
    "human_override": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["overridden_by", "override_reason", "original_gate_result", "overridden_at"],
      "properties": {
        "overridden_by": {
          "type": "string",
          "minLength": 1,
          "description": "Identity of the human who overrode the gate decision"
        },
        "override_reason": {
          "type": "string",
          "minLength": 10,
          "description": "Detailed written reason for the override"
        },
        "original_gate_result": {
          "type": "string",
          "enum": ["PASSED", "CONDITIONAL", "BLOCKED"],
          "description": "Original gate result before override"
        },
        "overridden_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "feedback_score": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5
    },
    "metrics": {
      "$ref": "#/definitions/metrics"
    },
    "assumptions_catalog": {
      "type": "array",
      "description": "隐性假设完整目录（REQ阶段扩展）",
      "items": {
        "type": "object",
        "required": ["assumption_id", "assumption", "location", "risk_level", "validation_method"],
        "properties": {
          "assumption_id": { "type": "string" },
          "assumption": { "type": "string" },
          "location": {
            "type": "array",
            "items": { "type": "string" }
          },
          "risk_level": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "consequence_if_invalid": { "type": "string" },
          "validation_method": { "type": "string" },
          "related_issues": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "reviewer_role": {
      "type": "string",
      "enum": ["Devil-BA", "Devil-UX", "Devil-Tech", "Judge-Req"]
    }
  },
  "definitions": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "dimension", "severity", "description", "evidence", "impact", "recommendation"],
      "properties": {
        "issue_id": {
          "type": "string",
          "pattern": "^REQ-[0-9]{3}$"
        },
        "dimension": {
          "type": "string",
          "enum": ["security", "maintainability", "performance", "reliability", "scalability", "usability", "compliance", "correctness"],
          "description": "隐性假设挖掘/需求矛盾检测 → correctness; ROI合理性挑战/范围蔓延预警 → maintainability; 安全需求缺陷 → security; 综合判定 → usability"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "category": {
          "type": "string",
          "description": "问题分类，安全类使用 CWE 编号"
        },
        "description": { "type": "string" },
        "code_snippet": {
          "type": "string",
          "description": "相关需求/设计片段"
        },
        "evidence": { "type": "string" },
        "impact": { "type": "string" },
        "recommendation": { "type": "string" },
        "line_number": {
          "type": "integer",
          "minimum": 1
        },
        "location": { "type": "string" },
        "attack_vector": {
          "type": "string",
          "description": "安全类问题的攻击向量"
        },
        "recurring": { "type": "boolean", "default": false },
        "recurring_count": { "type": "integer", "minimum": 1 },
        "first_seen": { "type": "string", "format": "date-time" },
        "assumption_if_any": { "type": "string" },
        "related_issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "scores": {
      "type": "object",
      "required": ["overall", "security", "maintainability", "performance"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 100 },
        "security": { "type": "number", "minimum": 0, "maximum": 100 },
        "maintainability": { "type": "number", "minimum": 0, "maximum": 100 },
        "performance": { "type": "number", "minimum": 0, "maximum": 100 },
        "correctness": { "type": "number", "minimum": 0, "maximum": 100 },
        "usability": { "type": "number", "minimum": 0, "maximum": 100 },
        "compliance": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "issue_density": { "type": "number" },
        "critical_issue_ratio": { "type": "number" },
        "recurring_issue_ratio": { "type": "number" },
        "fix_duration_hours": { "type": ["number", "null"] }
      }
    }
  }
}
