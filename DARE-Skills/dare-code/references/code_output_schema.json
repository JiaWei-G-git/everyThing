{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DARE-CODE Review Output Schema",
  "description": "D.A.R.E.框架代码阶段对抗审查输出格式规范，与dare-report/references/unified_schema.json对齐",
  "type": "object",
  "required": [
    "record_id",
    "stage",
    "timestamp",
    "intensity_level",
    "review_summary",
    "issues",
    "scores",
    "gate_result",
    "confidence_score",
    "escalation_triggered"
  ],
  "additionalProperties": true,
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^dare-[0-9]{8}-[0-9]{3}$"
    },
    "stage": {
      "type": "string",
      "enum": ["CODE"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "intensity_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "mode": {
      "type": "string",
      "enum": ["debate", "review", "audit"]
    },
    "participants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target": {
      "type": "object",
      "properties": {
        "file_path": { "type": "string" },
        "commit_sha": { "type": "string" },
        "module": { "type": "string" },
        "pr_number": { "type": "string" }
      }
    },
    "debate_rounds": {
      "type": "integer",
      "minimum": 0
    },
    "review_summary": {
      "type": "string",
      "maxLength": 200,
      "description": "整体审查结论摘要，不超过200字"
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/definitions/issue" }
    },
    "scores": {
      "$ref": "#/definitions/scores"
    },
    "gate_result": {
      "type": "string",
      "enum": ["PASSED", "CONDITIONAL", "BLOCKED"]
    },
    "gate_reason": {
      "type": "string",
      "description": "门禁判定原因说明"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Agent对审查结果的置信度（0=完全不确定，1=完全确信）"
    },
    "escalation_triggered": {
      "type": "boolean",
      "default": false
    },
    "escalation_level": {
      "type": ["string", "null"],
      "enum": ["L1", "L2", "L3", null]
    },
    "human_override": {
      "type": ["object", "null"]
    },
    "feedback_score": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5
    },
    "metrics": {
      "$ref": "#/definitions/metrics"
    },
    "file_path": {
      "type": "string",
      "description": "被审查文件的绝对路径（遗留字段，已放入target.file_path）"
    },
    "blocker_count": {
      "type": "integer",
      "minimum": 0,
      "description": "阻塞合并的问题数量（遗留字段，可由gate_result推导）"
    },
    "debate_context": {
      "type": "object",
      "description": "多Agent辩论模式下的额外上下文（可选）",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["single", "debate", "council", "self_adversarial"]
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Devil-Code", "Devil-Sec", "Devil-Maint", "Judge-Code"]
          }
        },
        "rounds": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "definitions": {
    "issue": {
      "type": "object",
      "required": ["issue_id", "dimension", "severity", "description", "evidence", "impact", "recommendation"],
      "properties": {
        "issue_id": {
          "type": "string",
          "pattern": "^CODE-[0-9]{3}$",
          "description": "问题唯一标识"
        },
        "dimension": {
          "type": "string",
          "enum": ["correctness", "security", "maintainability", "performance"],
          "description": "实现方案挑战 → correctness; 安全漏洞扫描 → security; 可维护性评估 → maintainability; 性能瓶颈识别 → performance"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "严重程度: critical=阻塞, high=24h修复, medium=Sprint内, low=建议"
        },
        "category": {
          "type": "string",
          "description": "问题分类。安全类使用CWE编号(如CWE-89)，其他使用分类名称(如CODE_SMELL, PERFORMANCE)",
          "examples": ["CWE-89", "CWE-22", "CWE-200", "CODE_SMELL", "PERFORMANCE", "COMPLEXITY", "STYLE"]
        },
        "description": { "type": "string" },
        "code_snippet": {
          "type": "string",
          "description": "相关代码片段。包含足够上下文理解问题，通常3-10行。"
        },
        "evidence": { "type": "string" },
        "impact": { "type": "string" },
        "recommendation": { "type": "string" },
        "line_number": {
          "type": "integer",
          "minimum": 1,
          "description": "问题所在行号"
        },
        "location": {
          "type": "string",
          "description": "file_path:line_number 的合成位置"
        },
        "attack_vector": {
          "type": "string",
          "description": "攻击向量（安全类问题必填，其他可选）"
        },
        "recurring": { "type": "boolean", "default": false },
        "recurring_count": { "type": "integer", "minimum": 1 },
        "first_seen": { "type": "string", "format": "date-time" }
      }
    },
    "scores": {
      "type": "object",
      "required": ["overall", "security", "maintainability", "performance"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 100, "description": "security/maintainability/performance 加权平均" },
        "security": { "type": "number", "minimum": 0, "maximum": 100 },
        "maintainability": { "type": "number", "minimum": 0, "maximum": 100 },
        "performance": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "issue_density": { "type": "number" },
        "critical_issue_ratio": { "type": "number" },
        "recurring_issue_ratio": { "type": "number" },
        "fix_duration_hours": { "type": "number" }
      }
    }
  }
}
