{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DARE-Test Output Schema",
  "description": "TEST-Challenger对抗审查输出格式规范，与dare-report/references/unified_schema.json对齐",
  "type": "object",
  "required": [
    "record_id",
    "stage",
    "timestamp",
    "intensity_level",
    "review_summary",
    "issues",
    "scores",
    "gate_result",
    "confidence_score",
    "escalation_triggered"
  ],
  "additionalProperties": true,
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^dare-[0-9]{8}-[0-9]{3}$"
    },
    "stage": {
      "type": "string",
      "enum": ["TEST"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "intensity_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "mode": {
      "type": "string",
      "enum": ["debate", "review", "audit", "council"]
    },
    "participants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target": {
      "type": "object",
      "properties": {
        "file_path": { "type": "string" },
        "commit_sha": { "type": "string" },
        "module": { "type": "string" },
        "pr_number": { "type": "string" }
      }
    },
    "debate_rounds": {
      "type": "integer",
      "minimum": 0
    },
    "review_summary": {
      "type": "string",
      "maxLength": 200,
      "description": "审查结论摘要，200字以内"
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/definitions/issue" }
    },
    "scores": {
      "$ref": "#/definitions/scores"
    },
    "gate_result": {
      "type": "string",
      "enum": ["PASSED", "CONDITIONAL", "BLOCKED"]
    },
    "gate_reason": {
      "type": "string",
      "description": "门禁判定原因说明"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "escalation_triggered": {
      "type": "boolean",
      "default": false
    },
    "escalation_level": {
      "type": ["string", "null"],
      "enum": ["L1", "L2", "L3", null]
    },
    "human_override": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["overridden_by", "override_reason", "original_gate_result", "overridden_at"],
      "properties": {
        "overridden_by": {
          "type": "string",
          "minLength": 1,
          "description": "Identity of the human who overrode the gate decision"
        },
        "override_reason": {
          "type": "string",
          "minLength": 10,
          "description": "Detailed written reason for the override"
        },
        "original_gate_result": {
          "type": "string",
          "enum": ["PASSED", "CONDITIONAL", "BLOCKED"],
          "description": "Original gate result before override"
        },
        "overridden_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "feedback_score": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5
    },
    "metrics": {
      "$ref": "#/definitions/metrics"
    },
    "review_metadata": {
      "type": "object",
      "description": "审查会话元数据（TEST阶段扩展，record_id等已提升为顶层）",
      "properties": {
        "review_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reviewer_role": {
          "type": "string",
          "enum": ["Devil-Test", "Devil-Fuzz", "Devil-Chaos", "Judge-Test", "Multi-Agent-Committee"]
        },
        "adversarial_level": { "type": "integer", "minimum": 1, "maximum": 5 },
        "target_scope": {
          "type": "object",
          "properties": {
            "module_name": { "type": "string" },
            "test_files": { "type": "array", "items": { "type": "string" } },
            "source_files_under_test": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "test_coverage_assessment": {
      "type": "object",
      "description": "当前覆盖评估 across four dimensions（TEST阶段扩展）",
      "properties": {
        "functional_coverage": { "$ref": "#/definitions/coverage_dimension" },
        "branch_coverage": { "$ref": "#/definitions/coverage_dimension" },
        "boundary_coverage": { "$ref": "#/definitions/coverage_dimension" },
        "fault_coverage": { "$ref": "#/definitions/coverage_dimension" }
      }
    },
    "missing_test_cases": {
      "type": "array",
      "description": "识别为缺失的测试用例（TEST阶段扩展）",
      "items": {
        "type": "object",
        "required": ["case_id", "target_function", "test_type", "scenario", "input_data", "expected_behavior", "priority", "rationale"],
        "properties": {
          "case_id": { "type": "string" },
          "target_function": { "type": "string" },
          "test_type": {
            "type": "string",
            "enum": ["functional", "boundary", "fault_injection", "concurrency", "performance", "security", "recovery", "fuzz"]
          },
          "scenario": { "type": "string" },
          "input_data": { "type": "object" },
          "expected_behavior": { "type": "string" },
          "expected_result": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0-critical", "P1-high", "P2-medium", "P3-low"] },
          "rationale": { "type": "string" },
          "adversarial_role": { "type": "string", "enum": ["Devil-Test", "Devil-Fuzz", "Devil-Chaos", "Judge-Test"] }
        }
      }
    },
    "coverage_gaps": {
      "type": "array",
      "description": "高级覆盖缺口（TEST阶段扩展，同时也是issues数组的数据来源之一）",
      "items": {
        "type": "object",
        "required": ["gap_id", "category", "description", "affected_areas", "risk_level"],
        "properties": {
          "gap_id": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["functional", "branch", "boundary", "fault_tolerance", "concurrency", "integration", "security", "performance"]
          },
          "description": { "type": "string" },
          "affected_areas": { "type": "array", "items": { "type": "string" } },
          "risk_level": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "remediation": { "type": "string" }
        }
      }
    },
    "recommended_coverage_target": {
      "type": "object",
      "description": "Judge-Test推荐的风险驱动覆盖目标（TEST阶段扩展）",
      "properties": {
        "overall_strategy": { "type": "string" },
        "targets_by_risk_tier": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tier": { "type": "string" },
              "description": { "type": "string" },
              "branch_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
              "boundary_coverage_required": { "type": "boolean" },
              "boundary_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
              "fault_simulation_required": { "type": "boolean" },
              "concurrency_tests_required": { "type": "boolean" },
              "justification": { "type": "string" }
            }
          }
        },
        "priority_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "target": { "type": "string" },
              "effort_estimate": { "type": "string", "enum": ["small", "medium", "large"] },
              "impact": { "type": "string", "enum": ["critical", "high", "medium", "low"] }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "TEST审查汇总（遗留字段，gate_result已替代overall_risk_level）",
      "properties": {
        "total_missing_cases": { "type": "integer" },
        "critical_gaps_count": { "type": "integer" },
        "overall_risk_level": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "key_recommendation": { "type": "string" },
        "reviewer_signoff": { "type": "string" }
      }
    }
  },
  "definitions": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "dimension", "severity", "description", "evidence", "impact", "recommendation"],
      "properties": {
        "issue_id": {
          "type": "string",
          "pattern": "^TEST-[0-9]{3}$"
        },
        "dimension": {
          "type": "string",
          "enum": ["security", "maintainability", "performance", "reliability", "scalability", "usability", "compliance", "correctness"],
          "description": "functional/branch/boundary → correctness; fault_tolerance/integration → reliability; concurrency → performance; security → security"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "category": {
          "type": "string",
          "description": "问题分类，安全类使用 CWE 编号"
        },
        "description": { "type": "string" },
        "code_snippet": {
          "type": "string",
          "description": "相关测试/被测代码片段"
        },
        "evidence": { "type": "string" },
        "impact": { "type": "string" },
        "recommendation": { "type": "string" },
        "line_number": {
          "type": "integer",
          "minimum": 1
        },
        "location": { "type": "string" },
        "attack_vector": {
          "type": "string",
          "description": "安全类问题的攻击向量"
        },
        "recurring": { "type": "boolean", "default": false },
        "recurring_count": { "type": "integer", "minimum": 1 },
        "first_seen": { "type": "string", "format": "date-time" }
      }
    },
    "scores": {
      "type": "object",
      "required": ["overall", "security", "maintainability", "performance"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 100, "description": "functional/branch/boundary/fault覆盖率平均值" },
        "security": { "type": "number", "minimum": 0, "maximum": 100, "description": "从security相关gap和fault覆盖率推导" },
        "maintainability": { "type": "number", "minimum": 0, "maximum": 100, "description": "从branch覆盖率推导" },
        "performance": { "type": "number", "minimum": 0, "maximum": 100, "description": "从concurrency/performance相关gap推导" },
        "reliability": { "type": "number", "minimum": 0, "maximum": 100, "description": "从fault覆盖率推导" },
        "correctness": { "type": "number", "minimum": 0, "maximum": 100 },
        "usability": { "type": "number", "minimum": 0, "maximum": 100 },
        "compliance": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "issue_density": { "type": "number" },
        "critical_issue_ratio": { "type": "number" },
        "recurring_issue_ratio": { "type": "number" },
        "fix_duration_hours": { "type": ["number", "null"] }
      }
    },
    "coverage_dimension": {
      "type": "object",
      "properties": {
        "score": { "type": "integer" },
        "max_score": { "type": "integer" },
        "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
        "findings": { "type": "array" },
        "uncovered_branches": { "type": "array" },
        "untested_boundaries": { "type": "array" },
        "untested_faults": { "type": "array" }
      }
    }
  }
}
