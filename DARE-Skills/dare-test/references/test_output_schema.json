{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DARE-Test Output Schema",
  "description": "JSON Schema for TEST-Challenger adversarial review output. Validates the structured report generated by Devil-Test, Devil-Fuzz, Devil-Chaos, and Judge-Test roles.",
  "type": "object",
  "required": [
    "review_metadata",
    "test_coverage_assessment",
    "missing_test_cases",
    "coverage_gaps",
    "recommended_coverage_target",
    "summary"
  ],
  "properties": {
    "review_metadata": {
      "type": "object",
      "description": "Metadata about this adversarial review session",
      "required": ["review_id", "timestamp", "reviewer_role", "adversarial_level", "target_scope"],
      "properties": {
        "review_id": {
          "type": "string",
          "description": "Unique identifier for this review session"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the review was generated"
        },
        "reviewer_role": {
          "type": "string",
          "enum": ["Devil-Test", "Devil-Fuzz", "Devil-Chaos", "Judge-Test", "Multi-Agent-Committee"],
          "description": "The adversarial role that produced this review"
        },
        "adversarial_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Intensity level of the adversarial review (1-5)"
        },
        "target_scope": {
          "type": "object",
          "description": "What is being reviewed",
          "required": ["module_name", "test_files", "source_files_under_test"],
          "properties": {
            "module_name": { "type": "string" },
            "test_files": {
              "type": "array",
              "items": { "type": "string" }
            },
            "source_files_under_test": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "test_coverage_assessment": {
      "type": "object",
      "description": "Current coverage assessment across four dimensions",
      "required": ["functional_coverage", "branch_coverage", "boundary_coverage", "fault_coverage"],
      "properties": {
        "functional_coverage": {
          "type": "object",
          "required": ["score", "max_score", "percentage", "findings"],
          "properties": {
            "score": { "type": "integer", "description": "Number of functional points covered" },
            "max_score": { "type": "integer", "description": "Total identifiable functional points" },
            "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
            "findings": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["function", "covered", "severity"],
                "properties": {
                  "function": { "type": "string" },
                  "covered": { "type": "boolean" },
                  "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
                  "note": { "type": "string" }
                }
              }
            }
          }
        },
        "branch_coverage": {
          "type": "object",
          "required": ["score", "max_score", "percentage", "uncovered_branches"],
          "properties": {
            "score": { "type": "integer" },
            "max_score": { "type": "integer" },
            "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
            "uncovered_branches": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["location", "condition", "consequence"],
                "properties": {
                  "location": { "type": "string", "description": "File and line reference" },
                  "condition": { "type": "string", "description": "The branch condition not tested" },
                  "consequence": { "type": "string", "description": "What could go wrong if this branch fails" }
                }
              }
            }
          }
        },
        "boundary_coverage": {
          "type": "object",
          "required": ["score", "max_score", "percentage", "untested_boundaries"],
          "properties": {
            "score": { "type": "integer" },
            "max_score": { "type": "integer" },
            "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
            "untested_boundaries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["parameter", "boundary_type", "risk_level"],
                "properties": {
                  "parameter": { "type": "string" },
                  "boundary_type": {
                    "type": "string",
                    "enum": ["min_value", "max_value", "empty", "null", "max_plus_one", "min_minus_one", "special_chars", "overflow", "type_mismatch", "format_invalid"]
                  },
                  "risk_level": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
                  "current_test": { "type": "string", "description": "What the current test does (if any)" },
                  "recommended_test": { "type": "string", "description": "What test should be added" }
                }
              }
            }
          }
        },
        "fault_coverage": {
          "type": "object",
          "required": ["score", "max_score", "percentage", "untested_faults"],
          "properties": {
            "score": { "type": "integer" },
            "max_score": { "type": "integer" },
            "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
            "untested_faults": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["fault_type", "dependency", "impact"],
                "properties": {
                  "fault_type": {
                    "type": "string",
                    "enum": ["timeout", "connection_refused", "service_down", "data_corruption", "latency_spike", "resource_exhaustion", "network_partition", "cascade_failure", "deadlock", "rate_limiting"]
                  },
                  "dependency": { "type": "string", "description": "The external dependency that could fail" },
                  "impact": { "type": "string", "description": "Impact on the system under test" },
                  "risk_level": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
                  "recommended_simulation": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "missing_test_cases": {
      "type": "array",
      "description": "Test cases identified as missing by the adversarial review",
      "items": {
        "type": "object",
        "required": ["case_id", "target_function", "test_type", "scenario", "input_data", "expected_behavior", "priority", "rationale"],
        "properties": {
          "case_id": {
            "type": "string",
            "description": "Unique identifier for this test case (e.g., TC-001)"
          },
          "target_function": {
            "type": "string",
            "description": "The function/method under test"
          },
          "test_type": {
            "type": "string",
            "enum": ["functional", "boundary", "fault_injection", "concurrency", "performance", "security", "recovery", "fuzz"],
            "description": "Category of the test"
          },
          "scenario": {
            "type": "string",
            "description": "Human-readable description of what this test validates"
          },
          "input_data": {
            "type": "object",
            "description": "Input parameters or state setup for the test",
            "properties": {
              "parameters": { "type": "object" },
              "preconditions": { "type": "array", "items": { "type": "string" } },
              "mock_setup": { "type": "string" }
            }
          },
          "expected_behavior": {
            "type": "string",
            "description": "What the correct behavior should be"
          },
          "expected_result": {
            "type": "string",
            "description": "Expected return value, exception, or state change"
          },
          "priority": {
            "type": "string",
            "enum": ["P0-critical", "P1-high", "P2-medium", "P3-low"],
            "description": "Priority based on risk and impact"
          },
          "rationale": {
            "type": "string",
            "description": "Why this test case is necessary"
          },
          "adversarial_role": {
            "type": "string",
            "enum": ["Devil-Test", "Devil-Fuzz", "Devil-Chaos", "Judge-Test"],
            "description": "Which role identified this gap"
          }
        }
      }
    },
    "coverage_gaps": {
      "type": "array",
      "description": "High-level coverage gaps that span multiple functions or system levels",
      "items": {
        "type": "object",
        "required": ["gap_id", "category", "description", "affected_areas", "risk_level"],
        "properties": {
          "gap_id": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["functional", "branch", "boundary", "fault_tolerance", "concurrency", "integration", "security", "performance"]
          },
          "description": { "type": "string" },
          "affected_areas": {
            "type": "array",
            "items": { "type": "string" }
          },
          "risk_level": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "remediation": { "type": "string", "description": "Recommended approach to close this gap" }
        }
      }
    },
    "recommended_coverage_target": {
      "type": "object",
      "description": "Risk-driven coverage targets recommended by Judge-Test",
      "required": ["overall_strategy", "targets_by_risk_tier"],
      "properties": {
        "overall_strategy": {
          "type": "string",
          "description": "Summary of the recommended coverage approach"
        },
        "targets_by_risk_tier": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tier", "description", "branch_coverage_pct", "boundary_coverage_required", "fault_simulation_required"],
            "properties": {
              "tier": { "type": "string", "description": "Risk tier name (e.g., critical, standard, internal)" },
              "description": { "type": "string", "description": "What functions fall into this tier" },
              "branch_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
              "boundary_coverage_required": { "type": "boolean" },
              "boundary_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
              "fault_simulation_required": { "type": "boolean" },
              "concurrency_tests_required": { "type": "boolean" },
              "justification": { "type": "string" }
            }
          }
        },
        "priority_actions": {
          "type": "array",
          "description": "Ordered list of actions to improve test coverage",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "target": { "type": "string" },
              "effort_estimate": { "type": "string", "enum": ["small", "medium", "large"] },
              "impact": { "type": "string", "enum": ["critical", "high", "medium", "low"] }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_missing_cases", "critical_gaps_count", "overall_risk_level", "key_recommendation"],
      "properties": {
        "total_missing_cases": { "type": "integer" },
        "critical_gaps_count": { "type": "integer" },
        "overall_risk_level": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "key_recommendation": { "type": "string", "description": "Single most important action to take" },
        "reviewer_signoff": { "type": "string", "description": "Signature line from the adversarial reviewer" }
      }
    }
  }
}
