{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DARERequest",
  "description": "D.A.R.E.框架对抗审查任务的输入配置Schema",
  "type": "object",
  "required": ["stage", "input_artifacts"],
  "additionalProperties": true,
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["REQ", "ARCH", "CODE", "TEST"],
      "description": "审查目标阶段"
    },
    "mode": {
      "type": "string",
      "enum": ["debate", "review", "audit", "council"],
      "description": "编排模式：debate=双Agent辩论，review=单Agent审查，audit=深度审计，council=多Agent委员会。不指定时自动选择"
    },
    "intensity_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "对抗强度级别，不指定时使用阶段默认值"
    },
    "max_rounds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "default": 3,
      "description": "最大辩论轮次"
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "content"],
        "allOf": [
          {
            "if": {
              "properties": { "type": { "const": "file_path" } }
            },
            "then": {
              "properties": {
                "content": {
                  "type": "string",
                  "pattern": "^(?!/|[A-Za-z]:\\\\|.*\\.\\.).*$",
                  "description": "必须是仓库内的相对路径，禁止 .. 跳转和绝对路径"
                }
              }
            }
          }
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["text", "code", "url", "file_path"]
          },
          "content": {
            "type": "string",
            "description": "当 type=file_path 时，必须是仓库内的相对路径，禁止 .. 跳转"
          },
          "metadata": { "type": "object" }
        }
      }
    },
    "focus_areas": {
      "type": "array",
      "items": { "type": "string" },
      "description": "重点关注领域，如安全性、性能、可维护性"
    },
    "convergence_threshold": {
      "type": "string",
      "enum": ["consensus", "max_rounds", "no_new_args"],
      "default": "max_rounds",
      "description": "收敛条件优先级"
    },
    "trigger_type": {
      "type": "string",
      "enum": ["pull_request", "commit", "manual", "scheduled", "merge_request", "release"],
      "description": "触发对抗审查的事件类型，影响报告中的 trigger_type 和 trigger_ref 字段"
    },
    "trigger_ref": {
      "type": "string",
      "description": "触发事件引用，如 PR 编号、commit SHA、release tag 等，对应报告中的 trigger_ref"
    }
  }
}
